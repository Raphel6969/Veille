# AI Runtime Supervisor — local development configuration
# Copy to .env and fill in only if you opt in to real providers.

# --- Database (Phase 1+ persistence) ---
DATABASE_URL=postgresql://supervisor:supervisor_dev@localhost:5432/supervisor

# --- Redis (Phase 2+ budgets/counters) ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (Phase 1+ replay artifacts) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=supervisor-artifacts

# --- Model access (opt-in; mock is default) ---
# Set USE_MOCK_MODELS=false and provide a key to use real providers via LiteLLM.
USE_MOCK_MODELS=true
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LITELLM_MODEL=gpt-4o-mini

# --- Observability (Phase 1+) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=ai-runtime-supervisor

# --- Logging ---
LOG_LEVEL=INFO
